# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
**/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js and frontend builds
.next/
**/.next/
out/
**/out/

# production and backend builds
build/
**/build/
dist/
**/dist/

# misc
.DS_Store
*.pem
**/.DS_Store

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep out of git, allow .env.example)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Expo files
.expo/
**/.expo/
web-build/
**/web-build/

# Native builds
ios/
**/ios/
android/
**/android/

# Credentials & keystores
*.jks
*.p8
*.key
*.mobileprovision

# Outputs
*.apk
*.aab
*.ipa
